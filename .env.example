# MONOProject MCP Configuration
# Copy to .env and fill in values

# API base URL (no trailing slash)
MONO_API_URL=https://monoproject.dev/api/v1

# API token (create via Settings → API Tokens in MONOProject UI)
# Format: mono_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONO_API_TOKEN=mono_your_token_here

# Default workspace ID or slug (used when workspace_id is not specified in tool calls)
MONO_WORKSPACE_ID=your-workspace-slug
